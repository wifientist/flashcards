# Copy this file to api/.env and fill in real values.
# The app will refuse to start if JWT_SECRET_KEY is missing or a placeholder.

# development | production
ENVIRONMENT=development

# Redis (sessions, cache, rate-limit counters)
REDIS_URL_0=redis://localhost:6379/0
REDIS_URL_1=redis://localhost:6379/1
# REDIS_PASSWORD=

# Auth — generate a strong secret:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_DECODE_ALGO=HS256

# CORS — comma-separated browser origins allowed to make credentialed requests.
CORS_ORIGINS=http://localhost:5177,http://127.0.0.1:5177

# Cookies — "lax" is a sane default; use "none" only if frontend/api are
# cross-site AND served over HTTPS.
COOKIE_SAMESITE=lax
